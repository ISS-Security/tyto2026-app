- color = { 'owner' => 'bg-warning-subtle text-warning-emphasis', 'instructor' => 'bg-primary-subtle text-primary-emphasis', 'staff' => 'bg-info-subtle text-info-emphasis', 'student' => 'bg-secondary-subtle text-secondary-emphasis' }.fetch(role, 'bg-light text-dark')
span class="badge #{color}"
  = role
